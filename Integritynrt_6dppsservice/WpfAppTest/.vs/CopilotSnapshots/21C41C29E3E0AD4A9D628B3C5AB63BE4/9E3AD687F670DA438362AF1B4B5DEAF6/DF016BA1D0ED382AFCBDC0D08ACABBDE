    public partial class MainWindow : Window
    {
        public MainWindow()
        {
            InitializeComponent();
        }

        private void Button_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                // Navigate the Calibration WebView2 to the calibration page
                Calibration_Windows.Source = new Uri("https://192.168.150.9:8443/calibration.html");
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Failed to navigate to calibration page: {ex.Message}", "Navigation Error", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private void Button_Click_1(object sender, RoutedEventArgs e)
        {
            try
            {
                // Navigate the Status WebView2 to the status page (optional)
                Status_Windows.Source = new Uri("https://192.168.150.9:8443/status.html");
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Failed to navigate to status page: {ex.Message}", "Navigation Error", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }
    }
